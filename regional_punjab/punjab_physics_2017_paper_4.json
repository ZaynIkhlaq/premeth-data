    {
      "text": "The principle of an electric generator is based on:",
      "image": null,
      "subject": "Physics",
      "topic": "Magnetism and Electromagnetic Induction",
      "year": 2017,
      "options": [
        {
          "letter": "A",
          "text": "Biot-Savart's law",
          "isCorrect": false,
          "explanation": "Biot-Savart's law is related to the calculation of magnetic fields generated by current-carrying conductors, not the operation of electric generators."
        },
        {
          "letter": "B",
          "text": "Ampere's law",
          "isCorrect": false,
          "explanation": "Ampere's law is related to the relationship between electric current and magnetic fields, not the principle of electric generators."
        },
        {
          "letter": "C",
          "text": "Newton's law",
          "isCorrect": false,
          "explanation": "Newton's laws of motion are not the basis for the operation of electric generators."
        },
        {
          "letter": "D",
          "text": "Faraday's law",
          "isCorrect": true,
          "explanation": "The principle of an electric generator is based on Faraday's law of electromagnetic induction. This law states that a changing magnetic field induces an electromotive force (EMF) in a closed circuit. In the case of electric generators, the relative motion between a magnetic field and a coil of wire induces an EMF, generating electricity."
        }
      ],
      "explanation": "",
      "explanationImage": null,
      "hints": []
